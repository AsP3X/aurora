{
  "name": "aurora",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "concurrently \"pnpm run dev:backend\" \"pnpm run dev:frontend\" --names \"API,WEB\" --prefix-colors \"cyan,magenta\"",
    "dev:backend": "cd backend && cargo run",
    "dev:frontend": "cd frontend && pnpm dev",
    "build": "cd frontend && pnpm run build",
    "lint": "cd frontend && pnpm run lint",
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "fuse.js": "^7.3.0"
  }
}
