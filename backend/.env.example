# Database
DATABASE_URL=sqlite://aurora.db

# Search
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=aurora-master-key

# Backend secrets (auto-generated by init-env.sh if left as GENERATE_ME)
JWT_SECRET=GENERATE_ME
SIGNING_SECRET=GENERATE_ME
MASTER_SECRET=GENERATE_ME

# Object Storage (proxy mode is the default)
STORAGE_MODE=proxy
OBJECT_STORAGE_URL=http://localhost:9000
OBJECT_STORAGE_PUBLIC_URL=http://localhost:9000
OBJECT_STORAGE_BUCKET=music
OBJECT_STORAGE_JWT_SECRET=GENERATE_ME

# Misc
URL_EXPIRY_SECONDS=3600
RUST_LOG=info
BIND_ADDR=0.0.0.0:3000
MUSIC_DIR=/music
